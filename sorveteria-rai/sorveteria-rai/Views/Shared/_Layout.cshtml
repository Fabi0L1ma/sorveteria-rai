﻿
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SistemaWebMVC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SistemaWebMVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar d-flex flex-column flex-shrink-0 position-fixed">

            @* <button class="toggle-btn" onclick="toggleSidebar()">
                <i class="fas fa-chevron-left"></i>
            </button> *@

            <div class="p-4">
                <h4 class="logo-text fw-bold mb-0">Sorveteria</h4>
                <small class="text-white">Pedidos para Loja</small>
            </div>

            <div class="nav flex-column">
                
                <a class="sidebar-link text-decoration-none p-3" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-house me-3"></i>
                    <span class="hide-on-collapse">Home</span>
                </a>

                <a class="sidebar-link text-decoration-none p-3" asp-controller="Categoria" asp-action="Index">
                    <i class="fa-solid fa-building-user me-3"></i>
                    <span class="hide-on-collapse">Categoria</span>
                </a>
                
            </div>

            <div class="profile-section mt-auto p-4">
                <div class="d-flex align-items-center">
                    <img src="https://wallpapers.com/images/featured-full/homer-simpson-engracado-nv3un39cjzu6qjju.jpg" style="height:40px; width:50px" class="rounded-circle" alt="Profile">
                    <div class="ms-3 profile-info">
                        <h6 class="text-white mb-0">Homer Simpson</h6>
                        <small class="text-muted">Admin</small>
                    </div>
                </div>
            </div>
        </nav>

        <main class="main-content vw-100">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </main>

        @* <script>
            function toggleSidebar() {
                const sidebar = document.querySelector('.sidebar');
                sidebar.classList.toggle('collapsed');
            }
        </script> *@
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>